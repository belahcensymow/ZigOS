const std = @import("std");
const os = std.os.linux;
const posix = std.posix;

// --- DRM Definitions ---
const DRM_IOCTL_MODE_ATOMIC = 0xc03864bc;
const DRM_IOCTL_MODE_CREATEPROPBLOB = 0xc01064bd;
const DRM_MODE_ATOMIC_ALLOW_MODESET = 0x0080;

pub fn main() !void {
    // 1. Setup Environment
    _ = os.mount("devtmpfs", "/dev", "devtmpfs", 0, 0);
    _ = os.mkdirat(os.AT.FDCWD, "/sys", 0o755);
    _ = os.mount("sysfs", "/sys", "sysfs", 0, 0);

    std.debug.print("--- DRM Clean Scratchpad Start ---\n", .{});

    const fd = try posix.open("/dev/dri/card0", .{ .ACCMODE = .RDWR }, 0);
    defer posix.close(fd);

    // 2. Target Dimensions
    const w: u32 = 1280;
    const h: u32 = 800;

    // 3. Create Mode Blob
    var mode = std.mem.zeroInit(drm_mode_modeinfo, .{
        .hdisplay = @as(u16, @intCast(w)),
        .hsync_start = @as(u16, @intCast(w + 40)),
        .hsync_end = @as(u16, @intCast(w + 80)),
        .htotal = @as(u16, @intCast(w + 120)),
        .vdisplay = @as(u16, @intCast(h)),
        .vsync_start = @as(u16, @intCast(h + 10)),
        .vsync_end = @as(u16, @intCast(h + 20)),
        .vtotal = @as(u16, @intCast(h + 30)),
        .vrefresh = 60,
        .clock = 60 * (w + 120) * (h + 30) / 1000,
    });
    std.mem.copyForwards(u8, &mode.name, "1280x800");
    mode.flags = 0x1;
    mode.type = 0x40 | 0x02;

    var create_blob = struct { data: u64, len: u32, id: u32 }{
        .data = @intFromPtr(&mode),
        .len = @sizeOf(drm_mode_modeinfo),
        .id = 0,
    };
    _ = os.ioctl(fd, DRM_IOCTL_MODE_CREATEPROPBLOB, @intFromPtr(&create_blob));
    const mode_blob_id = create_blob.id;
    std.debug.print("[+] Mode Blob Created: {d}\n", .{mode_blob_id});

    // 4. Initialize Surfaces
    var buffers = [2]Surface{
        try Surface.init(fd, w, h),
        try Surface.init(fd, w, h),
    };

    // 5. Atomic Scratchpad IDs
    const crtc_id: u32 = 37;
    const plane_id: u32 = 33;
    const conn_id: u32 = 38;

    var objs = [_]u32{ crtc_id, plane_id, conn_id };
    var p_counts = [_]u32{ 2, 9, 1 };
    var props = [_]u32{
        22, 23,
        17, 20,
        15, 16,
        11, 12,
        21, 20,
    };

    var values = [_]u64{
        1,                 @as(u64, mode_blob_id),
        0,                 @as(u64, crtc_id),
        w,                 h,
        @as(u64, w) << 16, @as(u64, h) << 16,
        0,                 @as(u64, crtc_id),
    };

    var frame: u32 = 0;
    while (true) : (frame += 1) {
        const back = &buffers[frame % 2];
        @memset(back.ptr, 0xFF000000 | (@as(u32, frame % 255) << 8));

        values[2] = back.fb_id;

        var req = std.mem.zeroInit(drm_mode_atomic, .{
            .flags = DRM_MODE_ATOMIC_ALLOW_MODESET,
            .count_objs = 3,
            .objs_ptr = @intFromPtr(&objs),
            .count_props_ptr = @intFromPtr(&p_counts),
            .props_ptr = @intFromPtr(&props),
            .prop_values_ptr = @intFromPtr(&values),
        });

        const ret = os.ioctl(fd, DRM_IOCTL_MODE_ATOMIC, @intFromPtr(&req));
        if (ret != 0) {
            const err = posix.errno(ret);
            std.debug.print("Atomic Fail Frame {d}: Error {d}\n", .{ frame, err });
            break;
        }
        posix.nanosleep(0, 16_666_666);
    }
}

// --- Supporting Structures ---

const Surface = struct {
    fd: i32,
    handle: u32,
    fb_id: u32,
    size: u64,
    ptr: []u32,

    pub fn init(fd: i32, w: u32, h: u32) !Surface {
        var create = std.mem.zeroInit(struct {
            height: u32,
            width: u32,
            bpp: u32,
            flags: u32 = 0,
            handle: u32 = 0,
            pitch: u32 = 0,
            size: u64 = 0,
        }, .{ .width = w, .height = h, .bpp = 32 });

        _ = os.ioctl(fd, 0xc02064b2, @intFromPtr(&create));

        // Fixed: The kernel needs to write the result into this struct
        var add_fb = struct {
            fb_id: u32,
            width: u32,
            height: u32,
            pitch: u32,
            bpp: u32,
            depth: u32,
            handle: u32,
        }{
            .fb_id = 0,
            .width = w,
            .height = h,
            .pitch = create.pitch,
            .bpp = 32,
            .depth = 24,
            .handle = create.handle,
        };
        _ = os.ioctl(fd, 0xc01c64ae, @intFromPtr(&add_fb));

        var map = struct { handle: u32, pad: u32 = 0, offset: u64 = 0 }{ .handle = create.handle };
        _ = os.ioctl(fd, 0xc01064b3, @intFromPtr(&map));

        const mmap_ptr = try posix.mmap(
            null,
            create.size,
            posix.PROT.READ | posix.PROT.WRITE,
            .{ .TYPE = .SHARED },
            fd,
            @intCast(map.offset),
        );

        return .{
            .fd = fd,
            .handle = create.handle,
            .fb_id = add_fb.fb_id, // Now correctly contains the ID from the kernel
            .size = create.size,
            .ptr = @ptrCast(@alignCast(mmap_ptr)),
        };
    }
};

const drm_mode_modeinfo = extern struct {
    clock: u32,
    hdisplay: u16,
    hsync_start: u16,
    hsync_end: u16,
    htotal: u16,
    hskew: u16,
    vdisplay: u16,
    vsync_start: u16,
    vsync_end: u16,
    vtotal: u16,
    vscan: u16,
    vrefresh: u32,
    flags: u32,
    type: u32,
    name: [32]u8,
};

const drm_mode_atomic = extern struct {
    flags: u32,
    count_objs: u32,
    objs_ptr: u64,
    count_props_ptr: u64,
    props_ptr: u64,
    prop_values_ptr: u64,
    reserved: u64 = 0,
    user_data: u64 = 0,
};
